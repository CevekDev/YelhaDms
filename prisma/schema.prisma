generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Platform {
  WHATSAPP
  TELEGRAM
}

enum TokenTransactionType {
  PURCHASE
  USAGE
  REFUND
  BONUS
  TRIAL
  PROMO
  ADMIN_GRANT
}

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  UserRole  @default(USER)
  tokenBalance          Int       @default(0)
  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?
  twoFactorEnabled      Boolean   @default(false)
  twoFactorSecret       String?
  twoFactorBackupCodes  String[]
  requiresTwoFactor     Boolean   @default(false)
  twoFactorCode         String?
  twoFactorCodeExpiry   DateTime?
  unlimitedTokens       Boolean   @default(false)
  trialUsed             Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  connections           Connection[]
  tokenTransactions     TokenTransaction[]
  verificationTokens    UserVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  auditLogs             AuditLog[]
  promoCodeUses         PromoCodeUse[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Connection {
  id                   String    @id @default(cuid())
  userId               String
  platform             Platform
  name                 String
  businessName         String?
  avatar               String?
  isActive             Boolean   @default(true)

  // Twilio WhatsApp
  twilioWhatsAppNumber String?   // customer's linked WA number (e.g. +213...)

  // Telegram
  telegramBotToken     String?   @db.Text  // AES-256-GCM encrypted
  telegramBotUsername  String?
  telegramChatId       String?   // captured during setup
  telegramWebhookSet   Boolean   @default(false)

  // Bot configuration
  botName              String    @default("Assistant")
  botPersonality       Json?
  customInstructions   String?   @db.Text

  // Business hours
  businessHours        Json?
  timezone             String    @default("UTC")

  // Messages
  welcomeMessage       String?   @db.Text
  awayMessage          String?   @db.Text

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  predefinedMessages   PredefinedMessage[]
  conversations        Conversation[]
  botCommands          BotCommand[]
}

model PredefinedMessage {
  id           String   @id @default(cuid())
  connectionId String
  keywords     String[]
  response     String   @db.Text
  isActive     Boolean  @default(true)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model BotCommand {
  id           String   @id @default(cuid())
  connectionId String
  command      String
  description  String
  createdAt    DateTime @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String   @id @default(cuid())
  connectionId String
  externalId   String
  platform     Platform
  contactName  String?
  contactId    String
  isNew        Boolean  @default(true)
  lastMessage  DateTime @default(now())
  createdAt    DateTime @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([connectionId, contactId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  direction      String   // "inbound" | "outbound"
  content        String   @db.Text
  type           String   @default("text")  // "text" | "voice" | "image"
  tokensUsed     Int      @default(0)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model TokenTransaction {
  id                   String               @id @default(cuid())
  userId               String
  type                 TokenTransactionType
  amount               Int
  balance              Int
  description          String?
  chargilyCheckoutId   String?              // replaces stripePaymentIntentId
  createdAt            DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TokenPackage {
  id          String   @id @default(cuid())
  name        String
  tokens      Int
  price       Float    // in DZD
  currency    String   @default("DZD")
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  tokens          Int       @default(0)   // bonus tokens after purchase (0 = none)
  discountPercent Float?                  // % off purchase price (null = no discount)
  maxUses         Int       @default(1)
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  uses        PromoCodeUse[]
}

model PromoCodeUse {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  createdAt   DateTime  @default(now())

  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
}

model WaitlistEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  platform  String   // "instagram" | "facebook"
  createdAt DateTime @default(now())
}
